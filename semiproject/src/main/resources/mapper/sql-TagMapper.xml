<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cloud.mapper.TagMapper">

    <!-- 태그 자체 CRUD -->
    <insert id="insertTag">
        INSERT INTO tag (TAG_NAME) VALUES (#{tagName})
    </insert>

    <update id="updateTag">
        UPDATE tag SET TAG_NAME = #{tagName} WHERE TAG_ID = #{tagId}
    </update>

    <delete id="deleteTag">
        DELETE FROM tag WHERE TAG_ID = #{tagId}
    </delete>

    <select id="getAllTags" resultType="org.cloud.dto.Tag">
        SELECT 
            TAG_ID as tagId,
            TAG_NAME as tagName
        FROM tag 
        ORDER BY TAG_ID ASC
    </select>

    <!-- 레시피와 태그 연결 (중간 테이블 저장) -->
    <insert id="insertRecipeTag">
    INSERT INTO recipe_tag (RECIPE_ID, TAG_ID)
    VALUES (#{RECIPE_ID}, #{TAG_ID})
</insert>

    <!-- 레시피 수정 시 기존 태그 관계 끊기 -->
    <delete id="deleteRecipeTags">
        DELETE FROM recipe_tag WHERE RECIPE_ID = #{RECIPE_ID}
    </delete>

    <!-- 레시피 상세 조회 시 태그 정보 가져오기 (JOIN 활용) -->
    <select id="getTagsByRecipeId" resultType="org.cloud.dto.Tag">
    SELECT
        t.TAG_ID as tagId,
        t.TAG_NAME as tagName
    FROM tag t
    JOIN recipe_tag rt ON t.TAG_ID = rt.TAG_ID
    WHERE rt.RECIPE_ID = #{RECIPE_ID}
    ORDER BY t.TAG_ID ASC
    </select>

    <!-- 여러 레시피의 태그를 한 번에 조회 (N+1 방지용 배치 조회) -->
    <select id="selectTagsByRecipeIds" resultType="org.cloud.dto.RecipeTagRow">
        SELECT
            rt.RECIPE_ID AS recipeId,
            t.TAG_ID     AS tagId,
            t.TAG_NAME   AS tagName
        FROM recipe_tag rt
        JOIN tag t ON rt.TAG_ID = t.TAG_ID
        <where>
            <if test="recipeIds != null and recipeIds.size() > 0">
                rt.RECIPE_ID IN
                <foreach collection="recipeIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
        ORDER BY t.TAG_ID ASC
    </select>

</mapper>